spring:
  application:
    name: auth-service

rabbitmq:
  host: 127.0.0.1
  port: 5672
  username: guest
  password: guest


logging:
  level:
    root: INFO
    com.gatepay: DEBUG
    org.springframework: INFO

server:
  port: 8081
  error:
    include-stacktrace: NEVER
    include-message: ALWAYS

transaction:
  deposit-limit: 10000000
  withdrawal-limit: 5000000
  rapidTransactionThreshold: 5

jwt:
  secret: ${JWT_SECRET:U3Nh4sJt6+vGJx0XoRLtdmFY/NTK8omIGArWoUcfK8U}
  access-token-expiration-ms: 1800000
  refresh-token-expiration-ms: 86400000

# Eureka client configuration
eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/
    register-with-eureka: true
    fetch-registry: true
  instance:
    prefer-ip-address: true

# Feign client configuration
feign:
  client:
    config:
      default:
        connectTimeout: 5000
        readTimeout: 5000
