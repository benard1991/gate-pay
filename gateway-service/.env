# ==========================
# GATEWAY SERVICE ENVIRONMENT VARIABLES
# ==========================

# Server Configuration
SERVER_PORT=8080

# Spring Application
SPRING_APPLICATION_NAME=gateway-service

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Eureka Service Discovery
EUREKA_SERVER_URL=http://discovery-service:8761/eureka/
EUREKA_REGISTER=true
EUREKA_FETCH_REGISTRY=true
EUREKA_PREFER_IP=true

# JWT Configuration
JWT_SECRET=U3Nh4sJt6+vGJx0XoRLtdmFY/NTK8omIGArWoUcfK8U
JWT_EXPIRATION_MS=3600000

# Circuit Breaker Configuration
# Auth Service
AUTH_CB_FAILURE_RATE=50
AUTH_CB_SLIDING_WINDOW=20
AUTH_CB_MIN_CALLS=10
AUTH_CB_WAIT_DURATION=30s
AUTH_CB_TIMEOUT=6s

# User Service
USER_CB_FAILURE_RATE=50
USER_CB_SLIDING_WINDOW=20
USER_CB_MIN_CALLS=10
USER_CB_WAIT_DURATION=30s
USER_CB_TIMEOUT=6s

# KYC Service
KYC_CB_FAILURE_RATE=40
KYC_CB_SLIDING_WINDOW=20
KYC_CB_MIN_CALLS=10
KYC_CB_WAIT_DURATION=45s
KYC_CB_TIMEOUT=6s

# Notification Service
NOTIFICATION_CB_FAILURE_RATE=60
NOTIFICATION_CB_SLIDING_WINDOW=10
NOTIFICATION_CB_MIN_CALLS=5
NOTIFICATION_CB_WAIT_DURATION=30s
NOTIFICATION_CB_TIMEOUT=6s

# Payment Service
PAYMENT_CB_FAILURE_RATE=50
PAYMENT_CB_SLIDING_WINDOW=20
PAYMENT_CB_MIN_CALLS=10
PAYMENT_CB_WAIT_DURATION=30s
PAYMENT_CB_TIMEOUT=30s

# Gateway HTTP Client
GATEWAY_CONNECT_TIMEOUT=3000
GATEWAY_RESPONSE_TIMEOUT=5s

# Logging Level
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_GATEWAY=DEBUG
LOG_LEVEL_SECURITY=DEBUG
LOG_LEVEL_RESILIENCE=DEBUG

# Actuator
MANAGEMENT_ENDPOINTS_ENABLED=true
MANAGEMENT_HEALTH_SHOW_DETAILS=always

# CORS Configuration
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=*
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# Public Paths (comma-separated)
PUBLIC_PATHS="/api/v1/auth/initiateLogin,/api/v1/auth/verify-otp,/api/v1/auth/validate,/api/v1/auth/forgot-password,/api/v1/auth/reset-password,/api/v1/users/register,/api/ping,/actuator/health"

